{
  "name": "lending-borowing-app",
  "version": "1.0.0",
  "type": "module",
  "description": "A Midnight Network application created with create-mn-app",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run proof-server\" \"npm run watch\"",
    "watch": "nodemon --config nodemon.json",
    "setup": "npm run compile && npm run build && npm run deploy",
    "compile": "compactc compile contracts/lending-pool.compact contracts/managed/lending-pool",
    "compile:token": "compactc compile contracts/Atoken.compact contracts/managed/atoken",
    "compile:all": "npm run compile && npm run compile:token",
    "build": "tsc",
    "deploy": "npm run build && node dist/deploy.js",
    "deploy:token": "npm run build && node dist/deploy-token.js",
    "cli": "node dist/cli.js",
    "check-balance": "npm run build && node dist/check-balance.js",
    "health-check": "npm run build && node dist/health-check.js",
    "reset": "rm -rf contracts/managed deployment.json token-deployment.json dist && npm run compile",
    "reset:all": "rm -rf contracts/managed deployment.json token-deployment.json dist && npm run compile:all",
    "validate": "tsc --noEmit && npm run compile",
    "validate:all": "tsc --noEmit && npm run compile:all",
    "clean": "rm -rf dist contracts/managed deployment.json token-deployment.json",
    "proof-server": "docker run -p 6300:6300 midnightnetwork/proof-server:6.1.0-alpha.6 -- midnight-proof-server --network preview",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@midnight-ntwrk/testkit-js": "file:./midnight-ntwrk-testkit-js-3.0.0-alpha.11.tgz",
    "@midnight-ntwrk/compact-runtime": "0.11.0-rc.1",
    "@midnight-ntwrk/ledger-v6": "6.1.0-alpha.6",
    "@midnight-ntwrk/midnight-js-compact": "^3.0.0-alpha.14",
    "@midnight-ntwrk/midnight-js-contracts": "3.0.0-alpha.11",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "3.0.0-alpha.11",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "3.0.0-alpha.11",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "3.0.0-alpha.11",
    "@midnight-ntwrk/midnight-js-network-id": "3.0.0-alpha.11",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "3.0.0-alpha.11",
    "@midnight-ntwrk/midnight-js-types": "3.0.0-alpha.11",
    "@midnight-ntwrk/midnight-js-utils": "3.0.0-alpha.11",
    "@midnight-ntwrk/onchain-runtime-v1": "1.0.0-alpha.5",
    "@midnight-ntwrk/wallet-sdk-abstractions": "1.0.0-beta.9",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "1.0.0-beta.10",
    "@midnight-ntwrk/wallet-sdk-facade": "1.0.0-beta.12",
    "@midnight-ntwrk/wallet-sdk-hd": "3.0.0-beta.7",
    "@midnight-ntwrk/wallet-sdk-shielded": "1.0.0-beta.11",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "1.0.0-beta.14",
    "axios": "^1.7.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "chalk": "^5.3.0",
    "dotenv": "^16.3.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "midnight",
    "blockchain",
    "zero-knowledge",
    "privacy"
  ]
}
